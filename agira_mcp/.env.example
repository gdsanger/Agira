# --- Agira MCP server configuration ---

# Base URL of the Agira instance (no trailing slash, no /api/customgpt).
AGIRA_BASE_URL=http://localhost:8000

# Shared API secret (matches Agira's CUSTOMGPT_API_SECRET). Server-side only.
AGIRA_API_SECRET=change-me

# Only for local stdio testing: act as this user (their User.mcp_token).
# In HTTP/remote mode the token comes from the connection URL (?token=...)
# or the x-agira-user-token header instead, so leave this unset there.
AGIRA_USER_TOKEN=
